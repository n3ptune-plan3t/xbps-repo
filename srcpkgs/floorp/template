# Template file for 'floorp'
pkgname=floorp
version=12.12.0
revision=2
archs="x86_64"
build_helper="rust"
short_desc="Floorp browser (optimized for low-end Zen+ systems)"
maintainer="you <you@example.com>"
license="MPL-2.0"
homepage="https://floorp.app"

distfiles="https://github.com/Floorp-Projects/Floorp/archive/refs/tags/v${version}.tar.gz"
checksum=fe0b50524570f1ca6918e44d8b26fc92cb9d421c9693d23333601933845bd6da

# ── Build deps ─────────────────────────────────────────────
hostmakedepends="
 clang lld llvm
 rust cargo
 cbindgen python3 nodejs
 nasm yasm unzip zip pkg-config
"

makedepends="
 gtk+3-devel dbus-devel
 nss-devel nspr-devel
 libX11-devel libXcomposite-devel libXdamage-devel
 libXext-devel libXfixes-devel libXrandr-devel libXt-devel
 freetype-devel fontconfig-devel pango-devel atk-devel at-spi2-atk-devel
 libdrm-devel MesaLib-devel
 libevent-devel libvpx-devel libwebp-devel libpng-devel
 libjpeg-turbo-devel icu-devel harfbuzz-devel zlib-devel
"

depends="
 gtk+3 dbus
 nss nspr
 alsa-lib
 mesa-dri
 desktop-file-utils hicolor-icon-theme
"

# ── Configure ─────────────────────────────────────────────
do_configure() {
	cat > .mozconfig << 'EOF'
ac_add_options --enable-application=browser

# Toolchain
export CC=clang
export CXX=clang++
export AR=llvm-ar
export NM=llvm-nm
ac_add_options --enable-linker=lld

# ── CPU-specific (Zen+) ──
export CFLAGS="-O2 -pipe -march=znver1 -mtune=znver1 -fomit-frame-pointer -mavx2 -mfma -mbmi -mbmi2"
export CXXFLAGS="$CFLAGS"
export RUSTFLAGS="-C target-cpu=znver1 -C opt-level=3 -C codegen-units=1"

# ── Linker tuning ──
export LDFLAGS="-Wl,-O2,--as-needed,--gc-sections"

# ── Low RAM stability ──
mk_add_options MOZ_MAKE_FLAGS="-j2"
ac_add_options --disable-debug
ac_add_options --disable-debug-symbols
ac_add_options --disable-tests
ac_add_options --disable-crashreporter

# ── IMPORTANT: avoid build failures ──
# NO PGO
# NO FULL LTO
ac_add_options --enable-lto=thin

# ── System libraries ──
ac_add_options --with-system-nss
ac_add_options --with-system-nspr
ac_add_options --with-system-libevent
ac_add_options --with-system-libvpx
ac_add_options --with-system-webp
ac_add_options --with-system-jpeg
ac_add_options --with-system-png
ac_add_options --with-system-icu
ac_add_options --with-system-harfbuzz

# ── Wayland (better for AMD iGPU) ──
ac_add_options --enable-default-toolkit=cairo-gtk3-wayland

# ── Build dir ──
mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj-floorp
EOF
}

# ── Build ─────────────────────────────────────────────
do_build() {
	export MOZBUILD_STATE_PATH="${wrksrc}/mozbuild"
	export MACH_BUILD_PYTHON_NATIVE_PACKAGE_SOURCE=system
	export MOZ_NOSPAM=1

	./mach build
}

# ── Install ───────────────────────────────────────────
do_install() {
	local appdir=/usr/lib/floorp

	./mach package

	vmkdir ${appdir}
	vcopy obj-floorp/dist/floorp/* ${appdir}/

	chmod 755 ${DESTDIR}${appdir}/floorp

	# Wrapper (critical for AMD + low-end)
	vmkdir usr/bin
	cat > ${DESTDIR}/usr/bin/floorp << 'WRAP'
#!/bin/sh
export MOZ_ENABLE_WAYLAND=1
export MOZ_WAYLAND_USE_VAAPI=1
export MOZ_X11_EGL=1
export LIBVA_DRIVER_NAME=radeonsi
export MOZ_DISABLE_RDD_SANDBOX=1
export NO_AT_BRIDGE=1
exec /usr/lib/floorp/floorp "$@"
WRAP
	chmod 755 ${DESTDIR}/usr/bin/floorp

	# Desktop entry
	vmkdir usr/share/applications
	cat > ${DESTDIR}/usr/share/applications/floorp.desktop << 'DESK'
[Desktop Entry]
Name=Floorp
Exec=floorp %u
Icon=floorp
Type=Application
Categories=Network;WebBrowser;
DESK

	# Icons
	for size in 16 32 48 64 128; do
		vmkdir usr/share/icons/hicolor/${size}x${size}/apps
		if [ -f "${DESTDIR}${appdir}/browser/chrome/icons/default/default${size}.png" ]; then
			vinstall "${DESTDIR}${appdir}/browser/chrome/icons/default/default${size}.png" \
				644 usr/share/icons/hicolor/${size}x${size}/apps floorp.png
		fi
	done

	# ── Low-end performance prefs ──
	vmkdir ${appdir}/defaults/pref
	cat > ${DESTDIR}${appdir}/defaults/pref/lowend.js << 'PREFS'
pref("dom.ipc.processCount", 2);
pref("media.ffmpeg.vaapi.enabled", true);
pref("media.hardware-video-decoding.force-enabled", true);
pref("network.predictor.enabled", false);
pref("network.prefetch-next", false);
pref("toolkit.telemetry.enabled", false);
pref("browser.cache.disk.enable", true);
pref("browser.cache.memory.enable", true);
pref("browser.sessionstore.interval", 60000);
pref("toolkit.cosmeticAnimations.enabled", false);
PREFS
}

post_install() {
	update-desktop-database usr/share/applications 2>/dev/null || true
	gtk-update-icon-cache -f -t usr/share/icons/hicolor 2>/dev/null || true
}
