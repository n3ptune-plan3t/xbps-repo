do_configure() {
	cat > ${wrksrc}/.mozconfig << 'MOZCONFIG'
ac_add_options --enable-application=browser

export CC=clang
export CXX=clang++
export AR=llvm-ar
export NM=llvm-nm
export RANLIB=llvm-ranlib
ac_add_options --enable-linker=lld

export CFLAGS="-march=znver1 -mtune=znver1 -O2 -pipe"
export CXXFLAGS="-march=znver1 -mtune=znver1 -O2 -pipe"

export RUSTFLAGS="-C target-cpu=znver1 -C opt-level=3"
export RUSTC_OPT_LEVEL=2

ac_add_options --enable-lto=thin
ac_add_options MOZ_PGO=1

ac_add_options --enable-release
ac_add_options --enable-strip
ac_add_options --enable-install-strip
ac_add_options --disable-debug
ac_add_options --disable-tests

ac_add_options --with-system-nss
ac_add_options --with-system-nspr
ac_add_options --with-system-libevent
ac_add_options --with-system-libvpx
ac_add_options --with-system-webp
ac_add_options --with-system-jpeg
ac_add_options --with-system-png
ac_add_options --with-system-icu
ac_add_options --with-system-harfbuzz
ac_add_options --with-system-av1

ac_add_options --enable-default-toolkit=cairo-gtk3-wayland-only

ac_add_options --disable-crashreporter
ac_add_options --disable-updater
ac_add_options --disable-maintenance-service
ac_add_options --disable-backgroundtasks

mk_add_options MOZ_OBJDIR=@TOPSRCDIR@/obj-floorp
mk_add_options MOZ_MAKE_FLAGS="-j${XBPS_MAKEJOBS}"
MOZCONFIG
}

do_build() {
	export NODE_OPTIONS="--experimental-modules --no-warnings"
	if [ -f tools/feles-build/build.js ]; then
		node tools/feles-build/build.js --phase before-mach || true
	fi
	./mach build
	if [ -f tools/feles-build/build.js ]; then
		node tools/feles-build/build.js --phase after-mach || true
	fi
}

do_install() {
	local appdir=/usr/lib/floorp

	./mach package
	local pkg
	pkg=$(ls obj-floorp/dist/floorp-*.tar.bz2 2>/dev/null | head -1)
	if [ -z "$pkg" ]; then
		vmkdir ${appdir}
		vcopy obj-floorp/dist/floorp/* ${appdir}/
	else
		bsdtar -xf "$pkg" -C ${DESTDIR}/usr/lib/
	fi

	chmod 755 ${DESTDIR}${appdir}/floorp

	vmkdir usr/bin
	cat > ${DESTDIR}/usr/bin/floorp << 'WRAPPER'
#!/bin/sh
export MOZ_ENABLE_WAYLAND=1
export LIBVA_DRIVER_NAME=radeonsi
export MOZ_DISABLE_RDD_SANDBOX=1
export NO_AT_BRIDGE=1
export MOZ_DBUS_REMOTE=1
exec /usr/lib/floorp/floorp "$@"
WRAPPER
	chmod 755 ${DESTDIR}/usr/bin/floorp

	vmkdir usr/share/applications
	cat > ${DESTDIR}/usr/share/applications/floorp.desktop << 'DESKTOP'
[Desktop Entry]
Version=1.0
Name=Floorp
GenericName=Web Browser
Comment=Fast, customizable, privacy-focused web browser
Exec=floorp %u
Icon=floorp
Terminal=false
Type=Application
Categories=Network;WebBrowser;
MimeType=text/html;text/xml;application/xhtml+xml;x-scheme-handler/http;x-scheme-handler/https;
StartupNotify=true
StartupWMClass=floorp
Actions=new-window;new-private-window;

[Desktop Action new-window]
Name=New Window
Exec=floorp --new-window

[Desktop Action new-private-window]
Name=New Private Window
Exec=floorp --private-window
DESKTOP

	for size in 16 32 48 64 128; do
		local icondir="usr/share/icons/hicolor/${size}x${size}/apps"
		vmkdir ${icondir}
		if [ -f "${DESTDIR}${appdir}/browser/chrome/icons/default/default${size}.png" ]; then
			vinstall "${DESTDIR}${appdir}/browser/chrome/icons/default/default${size}.png" \
				644 ${icondir} floorp.png
		fi
	done

	vmkdir ${appdir}/defaults/pref
	cat > ${DESTDIR}${appdir}/defaults/pref/lowend.js << 'PREFS'
pref("dom.ipc.processCount",                         2);
pref("dom.ipc.processCount.webIsolated",             1);
pref("media.ffmpeg.vaapi.enabled",                   true);
pref("media.hardware-video-decoding.force-enabled",  true);
pref("ui.prefersReducedMotion",                      1);
pref("toolkit.cosmeticAnimations.enabled",           false);
pref("browser.tabs.remote.warmup.enabled",           false);
pref("browser.tabs.remote.warmup.maxTabs",           0);
pref("network.prefetch-next",                        false);
pref("network.dns.disablePrefetch",                  true);
pref("network.http.speculative-parallel-limit",      0);
pref("network.predictor.enabled",                    false);
pref("browser.cache.disk.enable",                    true);
pref("browser.cache.memory.enable",                  true);
pref("browser.cache.memory.capacity",                32768);
pref("browser.cache.disk.capacity",                  262144);
pref("browser.sessionstore.interval",                60000);
pref("browser.sessionstore.max_tabs_undo",           5);
pref("browser.sessionstore.max_windows_undo",        1);
pref("toolkit.telemetry.enabled",                    false);
pref("toolkit.telemetry.unified",                    false);
pref("datareporting.healthreport.uploadEnabled",     false);
pref("datareporting.policy.dataSubmissionEnabled",   false);
pref("breakpad.reportURL",                           "");
pref("browser.crashReports.unsubmittedCheck.enabled", false);
pref("extensions.pocket.enabled",                    false);
pref("extensions.screenshots.disabled",              true);
PREFS
}

post_install() {
	update-desktop-database usr/share/applications 2>/dev/null || true
	gtk-update-icon-cache -f -t usr/share/icons/hicolor 2>/dev/null || true
	xbps-alternatives --group x-www-browser --add floorp:/usr/bin/floorp 2>/dev/null || true
}

post_remove() {
	update-desktop-database usr/share/applications 2>/dev/null || true
	gtk-update-icon-cache -f -t usr/share/icons/hicolor 2>/dev/null || true
}
